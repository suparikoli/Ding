 "doctype": "Print Format",
 "font": "Default",
 "font_size": 14,
 "html": "<div class=\"day-plan-card\">\n  <style>\n    .day-plan-card { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; color: #111; }\n    .day-plan-card h1 { font-size: 22px; margin: 0 0 4px; }\n    .day-plan-card .sub { color: #666; font-size: 13px; margin-bottom: 16px; }\n    .day-plan-card .summary { display: grid; grid-template-columns: repeat(4, 1fr); gap: 8px; margin: 16px 0; }\n    .day-plan-card .summary div { background: #f3f4f6; padding: 10px; border-radius: 6px; text-align: center; }\n    .day-plan-card .summary .num { font-size: 20px; font-weight: 700; }\n    .day-plan-card .summary .lbl { font-size: 11px; color: #555; }\n    .day-plan-card table { width: 100%; border-collapse: collapse; margin-top: 8px; }\n    .day-plan-card th, .day-plan-card td { padding: 8px 10px; text-align: left; border-bottom: 1px solid #e5e7eb; vertical-align: top; }\n    .day-plan-card th { background: #f9fafb; font-size: 11px; text-transform: uppercase; color: #555; }\n    .day-plan-card .pill { font-size: 11px; padding: 2px 8px; border-radius: 999px; background: #e5e7eb; }\n    .day-plan-card .pill.done { background: #d1fae5; color: #065f46; }\n    .day-plan-card .pill.skipped { background: #f3f4f6; color: #6b7280; }\n    .day-plan-card .pill.noshow { background: #fee2e2; color: #991b1b; }\n    .day-plan-card .pill.progress { background: #dbeafe; color: #1e40af; }\n    .day-plan-card .footer { margin-top: 24px; font-size: 11px; color: #888; border-top: 1px solid #e5e7eb; padding-top: 8px; }\n  </style>\n\n  <h1>{{ doc.name }}</h1>\n  <div class=\"sub\">\n    {{ frappe.utils.formatdate(doc.plan_date, \"long\") }}\n    &nbsp;·&nbsp; {{ doc.assigned_to }}\n    {%- if doc.territory %}&nbsp;·&nbsp; {{ doc.territory }}{% endif %}\n    &nbsp;·&nbsp; <strong>{{ doc.status }}</strong>\n  </div>\n\n  <div class=\"summary\">\n    <div><div class=\"num\">{{ doc.summary_planned_count or 0 }}</div><div class=\"lbl\">Planned</div></div>\n    <div><div class=\"num\">{{ doc.summary_completed_count or 0 }}</div><div class=\"lbl\">Done</div></div>\n    <div><div class=\"num\">{{ doc.summary_skipped_count or 0 }}</div><div class=\"lbl\">Skipped</div></div>\n    <div><div class=\"num\">{{ \"%.0f\" % (doc.adherence_pct or 0) }}%</div><div class=\"lbl\">Adherence</div></div>\n  </div>\n\n  <table>\n    <thead>\n      <tr>\n        <th style=\"width: 36px\">#</th>\n        <th>Client</th>\n        <th style=\"width: 80px\">Type</th>\n        <th style=\"width: 70px\">Time</th>\n        <th>Objective</th>\n        <th style=\"width: 90px\">Status</th>\n      </tr>\n    </thead>\n    <tbody>\n      {%- for s in (doc.stops or []) %}\n      <tr>\n        <td>{{ s.sequence or loop.index }}</td>\n        <td>\n          <strong>{{ s.client_name }}</strong><br/>\n          <span style=\"font-size:11px;color:#666\">{{ s.client_doctype }}</span>\n        </td>\n        <td>{{ s.visit_type or '' }}</td>\n        <td>{{ s.planned_start_time or '' }}</td>\n        <td>{{ s.objective or '' }}</td>\n        <td>\n          {%- set st = (s.status or 'Pending') %}\n          {%- if st == 'Done' %}<span class=\"pill done\">Done</span>\n          {%- elif st == 'Skipped' %}<span class=\"pill skipped\">Skipped</span>\n          {%- elif st == 'No Show' %}<span class=\"pill noshow\">No Show</span>\n          {%- elif st == 'In Progress' %}<span class=\"pill progress\">In Progress</span>\n          {%- else %}<span class=\"pill\">{{ st }}</span>\n          {%- endif %}\n        </td>\n      </tr>\n      {%- endfor %}\n    </tbody>\n  </table>\n\n  {%- if doc.notes %}\n  <p style=\"margin-top:16px\"><strong>Notes:</strong> {{ doc.notes }}</p>\n  {%- endif %}\n\n  <div class=\"footer\">\n    Generated {{ frappe.utils.format_datetime(frappe.utils.now(), 'medium') }}\n  </div>\n</div>",
